{
  "name": "thesis",
  "version": "1.0.0",
  "description": "Software tool to lint datasets of OpenAPI Specs and compute metadata",
  "main": "src/index.ts",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "jest",
    "test:cov": "jest --coverage",
    "lint": "npx eslint . -c package.json",
    "format:check": "prettier --check **/*.ts",
    "build": "rm -rf dist && npx tsc --p ./tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paul-brenker-1/thesis.git"
  },
  "author": "Paul Brenker",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/paul-brenker-1/thesis/issues"
  },
  "homepage": "https://github.com/paul-brenker-1/thesis#readme",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "axios-mock-adapter": "^2.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "prettier-eslint": "^16.3.0",
    "ts-jest": "^29.2.2",
    "typescript": "^5.5.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    }
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "useTabs": false,
    "semi": false,
    "singleQuote": true,
    "quoteProps": "as-needed",
    "jsxSingleQuote": false,
    "trailingComma": "none",
    "bracketSpacing": true,
    "bracketSameLine": true,
    "arrowParens": "avoid",
    "proseWrap": "always"
  },
  "dependencies": {
    "axios": "^1.7.3"
  }
}
