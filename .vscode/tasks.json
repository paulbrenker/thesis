{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Python tests",
      "type": "shell",
      "command": "poetry run pytest",
      "options": {
        "cwd": "${workspaceFolder}/analysis"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "Run TypeScript tests",
      "type": "shell",
      "command": "npm test",
      "options": {
        "cwd": "${workspaceFolder}/tool"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "Run all tests",
      "type": "shell",
      "command": "cd analysis && poetry run pytest && cd ../tool && npm test && echo 'All tests successful'",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always"
      },
      "problemMatcher": []
    }
  ]
}
